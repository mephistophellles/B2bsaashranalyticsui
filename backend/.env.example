# --- Обязательно в продакшене ---
# Случайная длинная строка для подписи JWT. Не используйте значение по умолчанию из кода.
SECRET_KEY=local-dev-secret-min-32-characters-long
# PostgreSQL в проде (пример):
# DATABASE_URL=postgresql+psycopg2://user:pass@db-host:5432/dbname
# Список origin фронта через запятую, только ваши HTTPS-домены:
# CORS_ORIGINS=https://app.example.com
# Явная метка прод-среды (усиливает проверку SECRET_KEY вместе с Postgres):
# POTENTIAL_ENV=production

# Только разработка: true — не завершать процесс при дефолтном SECRET_KEY + Postgres / POTENTIAL_ENV=production.
# В продакшене не задавать и не использовать.
# ALLOW_INSECURE_SECRET=true

# SQLite по умолчанию: файл backend/potential.db (абсолютный путь, один и тот же при любом cwd).
# Не используйте sqlite:///./potential.db — путь станет зависимым от каталога запуска.
# DATABASE_URL=
# DATABASE_URL=postgresql+psycopg2://user:pass@localhost:5432/potential

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
REDIS_URL=redis://localhost:6379/0

# Прод: false — только Alembic, без create_all при старте (см. README и deploy/PRODUCTION.md).
# RUN_CREATE_ALL=false
# В Docker API: один инстанс или отдельный job; при нескольких репликах K8s — только job.
# RUN_MIGRATIONS_ON_START=true

# Каталог артефактов ML (том в контейнере/сервере при использовании ML-рекомендаций).
# ML_ARTIFACT_DIR=/var/lib/potencore/ml_artifacts

# true — руководитель видит псевдонимы вместо ФИО (списки, дашборд, поиск)
# PRIVACY_HIDE_NAMES_FOR_MANAGERS=true

# Первый администратор без UI (после миграций, пустая users):
# PYTHONPATH=. python -m scripts.create_first_admin --username admin --password '...'
# или переменные BOOTSTRAP_ADMIN_USERNAME / BOOTSTRAP_ADMIN_PASSWORD

